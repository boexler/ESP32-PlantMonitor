# Seeed XIAO ESP32-C6 (ESP32-C6)
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Default: deep sleep mode (explicit for fresh clones before menuconfig)
CONFIG_PM_POWER_DEEP_SLEEP=y

# Default: external U.FL antenna (XIAO ESP32-C6 RF switch)
CONFIG_PM_WIFI_ANT_EXTERNAL=y

# Soil moisture: raw ADC calibration (see Kconfig help for meanings)
CONFIG_PM_SOIL_ADC_DISCONNECT_MAX=1000
CONFIG_PM_SOIL_ADC_WATER=1900
CONFIG_PM_SOIL_ADC_ILEX_VERY_WET=2185
CONFIG_PM_SOIL_ADC_VERY_DRY=2550
CONFIG_PM_SOIL_ADC_AIR=2650

# HTTPS device registry URLs (ESP_CONFIG_URL): mbedTLS requires a verification method
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
